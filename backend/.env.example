# Local development (from `npx prisma dev` output)
DATABASE_URL="postgresql://postgres:postgres@localhost:51214/template1?sslmode=disable"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:51214/template1?sslmode=disable"

# Optional — only needed for `prisma migrate dev` locally
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:51215/template1?sslmode=disable"

# Admin dashboard password (required for /admin)
ADMIN_PASSWORD="changeme"

# Railway sets DATABASE_URL automatically when Postgres is linked — do not copy local values there.
